# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# OPENROUTER_API_KEY: Required for OpenRouter API calls.
# Used by Workspace AI primitives (transform / architect / turn) AND legacy
# /api/chat path. Must be set for production.
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# VITE_GATEWAY_URL: URL del Shift AI Gateway (backend Python).
# En dev local se usa el proxy de Vite (dejar vacío).
# En producción, apuntar a la URL del gateway: https://gateway.shiftpn.com
VITE_GATEWAY_URL=""

# ──────────────────────────────────────────────────────────────────────
# Workspace integration (T1-T10)
# ──────────────────────────────────────────────────────────────────────
# These vars feed the Workspace BFF (src/routes/workspace.ts) and the
# clients in src/services/{peajeClient,puntoMedioClient,supabaseAdminClient,
# openRouterDirect,gammaApi,workspacePptxExport}.ts.
#
# Required in production: SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY,
# OPENROUTER_API_KEY, GAMMA_API_KEY, SWARM_API_URL.
# Everything else has a documented default.

# ── Cerebro / Swarm backend (Railway) ────────────────────────────────
# Production: https://shift-cerebro-production.up.railway.app
# Aliased: https://web-production-143119.up.railway.app
# Used by: server.ts /api/chat, peajeClient.ts (write), puntoMedioClient.ts (read).
SWARM_API_URL="https://shift-cerebro-production.up.railway.app"

# Tenant id for the Cerebro flywheel. Default 'shift'. Override only if
# Studio is white-labeled for a different tenant on this deploy.
CEREBRO_TENANT="shift"

# App id for multi-app v3 routing in Cerebro. Default 'studio' so insights
# land in the Studio bucket (peer of cl2/eco/sentinel). Do NOT change.
CEREBRO_APP_ID="studio"

# Kill switch for Peaje ingest hand-off. Set to "false" to disable the
# write side of the flywheel without a redeploy (e.g. during a Cerebro outage).
# Default: true.
PEAJE_ENABLED="true"

# ── Supabase (shared with Brandhub: project lqrrtyqhlpupmjzydbck) ────
# Server-only. NEVER expose SUPABASE_SERVICE_ROLE_KEY to the browser bundle.
# The supabaseAdminClient soft-fails if either is missing — the workspace
# router will reply 503 to every request.
SUPABASE_URL="https://lqrrtyqhlpupmjzydbck.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="MY_SUPABASE_SERVICE_ROLE_KEY"

# Frontend (Vite) — anon key only. RLS gates user access on the client side.
VITE_SUPABASE_URL="https://lqrrtyqhlpupmjzydbck.supabase.co"
VITE_SUPABASE_ANON_KEY="MY_SUPABASE_ANON_KEY"

# Set to "true" ONLY in dev / demo environments where there is no real
# Supabase auth. Skips Supabase init on the client and lets the BFF
# resolve user_id via x-user-id header or anon fallback. NEVER true in prod.
VITE_BYPASS_AUTH="false"

# Server-side companion to VITE_BYPASS_AUTH. When true, the BFF treats
# unauthenticated requests as the all-zero anon UUID instead of returning
# 401. NEVER true in prod — use only for ephemeral demo deploys.
STUDIO_ALLOW_ANON="false"

# ── Gamma (PPTX export) ──────────────────────────────────────────────
# Used by services/gammaApi.ts + workspacePptxExport.ts. If unset, the
# pptx export endpoint returns a structured error; md/docx still work.
GAMMA_API_KEY="MY_GAMMA_API_KEY"

# ── Workspace AI primitive model overrides (optional) ────────────────
# Defaults reviewed 2026-05-09. Gemini 3.x family wins price/quality
# (vision-native + 1M context + configurable thinking). Override only to
# A/B test (Sonnet 4.6 fallback for chat: anthropic/claude-sonnet-4.6).
# Cost target: ~55% reduction vs the prior Sonnet-4 + 2.5-Flash mix.
ARCHITECT_MODEL="google/gemini-3.1-pro-preview"
TURN_CLASSIFIER_MODEL="google/gemini-3.1-flash-lite-preview"
TURN_CHAT_MODEL="google/gemini-3-flash-preview"
TURN_EDIT_MODEL="google/gemini-3-flash-preview"
TRANSFORM_MODEL="google/gemini-3.1-flash-lite-preview"
TRANSFORM_EXPAND_MODEL="google/gemini-3.1-pro-preview"

# ── Express server (dev only) ─────────────────────────────────────────
# Vercel deploys do not honor PORT — the platform sets it. Local dev only.
PORT="3001"
NODE_ENV="development"
