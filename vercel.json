{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/workspace/(.*)", "destination": "/api/workspace" },
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/((?!api|assets|.*\\..*).*)", "destination": "/index.html" }
  ]
}
